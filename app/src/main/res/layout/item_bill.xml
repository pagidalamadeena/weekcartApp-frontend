<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="#F1F5F9"
    app:cardBackgroundColor="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="?attr/selectableItemBackground">

        <View
            android:id="@+id/ivBillIconBg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_input_field"
            android:backgroundTint="#F8FAFC"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <ImageView
            android:id="@+id/ivBillIcon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_cart_blue"
            app:tint="#64748B"
            app:layout_constraintTop_toTopOf="@id/ivBillIconBg"
            app:layout_constraintBottom_toBottomOf="@id/ivBillIconBg"
            app:layout_constraintStart_toStartOf="@id/ivBillIconBg"
            app:layout_constraintEnd_toEndOf="@id/ivBillIconBg" />

        <TextView
            android:id="@+id/tvBillId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="#000"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#1E293B"
            android:layout_marginStart="14dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivBillIconBg"
            app:layout_constraintVertical_chainStyle="packed"
            app:layout_constraintBottom_toTopOf="@id/tvBillDate" />

        <TextView
            android:id="@+id/tvBillDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            app:layout_constraintTop_toBottomOf="@id/tvBillId"
            app:layout_constraintStart_toStartOf="@id/tvBillId"
            app:layout_constraintBottom_toBottomOf="parent" />

        <TextView
            android:id="@+id/tvBillAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₹0.00"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#0F172A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tvBillStatus"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/tvBillStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status"
            android:textSize="11sp"
            android:textAllCaps="true"
            android:textStyle="bold"
            android:textColor="#10B981"
            android:paddingHorizontal="6dp"
            android:paddingVertical="2dp"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/tvBillAmount"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
